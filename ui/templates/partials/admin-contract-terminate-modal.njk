<section id="admin-contract-terminate-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="admin-contract-terminate-title">
  <div class="wf-modal__dialog wf-modal__dialog--form">
    <header class="wf-modal__header">
      <h2 id="admin-contract-terminate-title" class="wf-modal__title">Расторгнуть договор</h2>
      <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть">✕</a>
    </header>
    <div class="wf-modal__body">
      <form class="wf-form">
        <div class="wf-field">
          <label for="admin-contract-terminate-reason">Причина расторжения договора</label>
          <textarea id="admin-contract-terminate-reason" rows="3" placeholder="Кратко опишите причину расторжения (например: окончание аренды, длительная задолженность, решение клиента)."></textarea>
        </div>
        <div class="wf-actions">
          <button type="button">Расторгнуть договор</button>
        </div>
      </form>
    </div>
  </div>
</section>
