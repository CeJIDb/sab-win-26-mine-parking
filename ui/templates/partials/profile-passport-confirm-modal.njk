<section id="profile-passport-confirm-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="profile-passport-confirm-title">
  <div class="wf-modal__dialog wf-section">
    <header class="wf-modal__header">
      <h3 id="profile-passport-confirm-title">Подтверждение для просмотра паспортных данных</h3>
      <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
    </header>
    <form class="wf-form" id="profile-passport-confirm-form">
      <div class="wf-field">
        <label for="profile-passport-confirm-pwd">Пароль от личного кабинета</label>
        <input id="profile-passport-confirm-pwd" type="password" placeholder="Пароль" required autocomplete="current-password">
      </div>
      <div class="wf-actions">
        <a href="#passport-modal" class="wf-btn">Подтвердить и открыть паспортные данные</a>
      </div>
    </form>
  </div>
</section>
