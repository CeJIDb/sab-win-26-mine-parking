<section id="email-change-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="email-change-title">
  <div class="wf-modal__dialog wf-section">
    <header class="wf-modal__header">
      <h3 id="email-change-title">Смена e-mail</h3>
      <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
    </header>
    <form class="wf-form">
      <p class="wf-notice"><strong>Шаг 1.</strong> Подтвердите, что вы владеете текущим адресом e-mail.</p>
      <div class="wf-field">
        <label for="email-current">Текущий e-mail</label>
        <input id="email-current" type="email" placeholder="email@example.com">
      </div>
      <div class="wf-field">
        <button type="button">Отправить код на e-mail</button>
      </div>
      <div class="wf-field">
        <label for="email-current-code">Код из письма</label>
        <input id="email-current-code" type="text" inputmode="numeric" pattern="[0-9]*" placeholder="●●●●">
      </div>
      <div class="wf-actions">
        <button type="submit">Подтвердить текущий e-mail</button>
      </div>
    </form>
    <form class="wf-form">
      <p class="wf-notice"><strong>Шаг 2.</strong> Укажите новый e-mail и подтвердите его.</p>
      <div class="wf-field">
        <label for="email-new">Новый e-mail</label>
        <input id="email-new" type="email" placeholder="email@example.com" disabled>
      </div>
      <div class="wf-field">
        <button type="button" disabled>Отправить код на e-mail</button>
      </div>
      <div class="wf-field">
        <label for="email-new-code">Код из письма</label>
        <input id="email-new-code" type="text" inputmode="numeric" pattern="[0-9]*" placeholder="●●●●" disabled>
      </div>
      <div class="wf-actions">
        <button type="submit" disabled>Сохранить новый e-mail</button>
      </div>
    </form>
  </div>
</section>

