<section id="password-change-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="password-change-title">
  <div class="wf-modal__dialog wf-section">
    <header class="wf-modal__header">
      <h3 id="password-change-title">Смена пароля</h3>
      <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
    </header>
    <form class="wf-form">
      <div class="wf-field">
        <label for="prof-old-pwd">Текущий пароль</label>
        <input id="prof-old-pwd" type="password" placeholder="Текущий пароль">
      </div>
      <div class="wf-field">
        <label for="prof-new-pwd">Новый пароль</label>
        <input id="prof-new-pwd" type="password" placeholder="Новый пароль">
      </div>
      <div class="wf-field">
        <label for="prof-new-pwd-confirm">Подтверждение нового пароля</label>
        <input id="prof-new-pwd-confirm" type="password" placeholder="Повторите новый пароль">
      </div>
      <div class="wf-actions">
        <button type="submit">Изменить пароль</button>
      </div>
    </form>
  </div>
</section>

