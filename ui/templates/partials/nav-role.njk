{% set role = role | default('admin') %}
{% set current = nav_current | default('') %}

{% if role == 'admin' %}
<nav class="wf-nav wf-nav--admin" aria-label="Навигация ЛК администратора">
  <ul>
    <li><a href="index.html"{% if current == 'admin-index' %} aria-current="page"{% endif %}>Главная</a></li>
    <li><a href="sessions.html" class="wf-nav__link--has-sub" data-nav-sub="parking"{% if current in ['admin-sectors','admin-sessions','admin-tariffs','admin-notifications-manage','admin-admins'] %} aria-current="page"{% endif %}>Парковка</a></li>
    <li><a href="debts.html" class="wf-nav__link--has-sub" data-nav-sub="clients"{% if current in ['admin-contracts','admin-bookings','admin-debts','admin-clients','admin-client-sessions'] %} aria-current="page"{% endif %}>Клиенты</a></li>
    <li><a href="requests.html"{% if current == 'admin-requests' %} aria-current="page"{% endif %}>Обращения</a></li>
    <li><a href="kpp-panel.html" class="wf-nav__link--has-sub" data-nav-sub="kpp"{% if current in ['admin-kpp-dashboard','admin-kpp-log'] %} aria-current="page"{% endif %}>КПП</a></li>
    <li class="wf-nav__item--end"><a href="profile.html"{% if current == 'admin-profile' %} aria-current="page"{% endif %}>Профиль</a></li>
  </ul>
</nav>
{% else %}
<nav class="wf-nav" aria-label="Навигация КПП">
  <ul>
    <li><a href="index.html"{% if current == 'guard-index' %} aria-current="page"{% endif %}>КПП — панель</a></li>
    <li><a href="log.html"{% if current == 'guard-log' %} aria-current="page"{% endif %}>Журнал въезда‑выезда</a></li>
    <li class="wf-nav__item--end"><a href="profile.html"{% if current == 'guard-profile' %} aria-current="page"{% endif %}>Профиль</a></li>
  </ul>
</nav>
{% endif %}

