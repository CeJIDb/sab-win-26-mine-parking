{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-bookings' %}

{% block title %}Бронирования — ЛК админа{% endblock %}
{% block header_breadcrumbs %}<a href="debts.html">Клиенты</a><span class="wf-breadcrumbs__sep">/</span><span class="wf-breadcrumbs__current">Бронирования</span>{% endblock %}

{% block auxiliary_nav %}
  {% set nav_current = current_nav %}
  {% include "partials/nav-clients.njk" %}
{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление бронированиями</h2>
  </div>

<section class="wf-section">
  <h3>Реестр бронирований</h3>
  <form class="wf-form sessions-filters bookings-filters" aria-label="Фильтр реестра бронирований">
    <div class="filters-row">
      <div class="wf-field">
        <label for="search-booking-admin-number">№ брони / дата</label>
        <input id="search-booking-admin-number" type="text" placeholder="Б-1 или 25.02.2026">
      </div>
      <div class="wf-field">
        <label for="search-booking-admin-client-type">Тип клиента</label>
        <select id="search-booking-admin-client-type">
          <option value="">Любой</option>
          <option value="fl">ФЛ</option>
          <option value="yl">ЮЛ</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="search-booking-admin-client">Клиент</label>
        <input id="search-booking-admin-client" type="text" placeholder="ФИО или организация">
      </div>
      <div class="wf-field">
        <label for="search-booking-admin-date-from">Период с</label>
        <input id="search-booking-admin-date-from" type="date">
      </div>
      <div class="wf-field">
        <label for="search-booking-admin-date-to">по</label>
        <input id="search-booking-admin-date-to" type="date">
      </div>
      <div class="wf-field">
        <label for="search-booking-admin-status">Статус</label>
        <select id="search-booking-admin-status">
          <option value="">Любой</option>
          <option value="confirmed">Подтверждена</option>
          <option value="pending">Ожидает оплаты</option>
          <option value="completed">Завершена</option>
          <option value="cancelled">Отменена</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Применить</button>
        <button type="button">Сброс</button>
      </div>
    </div>
  </form>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">№ брони</th>
          <th scope="col">Тип клиента</th>
          <th scope="col">Клиент</th>
          <th scope="col">Период стоянки</th>
          <th scope="col">Тариф</th>
          <th scope="col">ТС (ГРЗ)</th>
          <th scope="col">Сектор / ПМ</th>
          <th scope="col">Статус</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href="#admin-modal-booking-view">Б-1</a></td>
          <td>ФЛ</td>
          <td><a href="#admin-modal-client-fl">Иванов Иван Иванович</a></td>
          <td>27.02.2026 19:00–22:00</td>
          <td>Почасовой A</td>
          <td>А123БВ777</td>
          <td>Сектор A</td>
          <td><span class="wf-badge">Подтверждена</span></td>
        </tr>
        <tr>
          <td><a href="#admin-modal-booking-view">Б-2</a></td>
          <td>ФЛ</td>
          <td><a href="#admin-modal-client-fl">Петров Пётр Петрович</a></td>
          <td>28.02.2026 08:00–10:00</td>
          <td>Почасовой B</td>
          <td>В456ГД199</td>
          <td>Сектор B</td>
          <td><span class="wf-badge">Ожидает оплаты</span></td>
        </tr>
        <tr>
          <td><a href="#admin-modal-booking-view">Б-3</a></td>
          <td>ЮЛ</td>
          <td><a href="#admin-modal-client-yl">ООО «Ромашка»</a></td>
          <td>26.02.2026 20:00–23:00</td>
          <td>Почасовой C</td>
          <td>А555АА750</td>
          <td>Сектор C</td>
          <td><span class="wf-badge">Завершена</span></td>
        </tr>
        <tr>
          <td><a href="#admin-modal-booking-view">Б-4</a></td>
          <td>ЮЛ</td>
          <td><a href="#admin-modal-client-yl">ООО «Ромашка»</a></td>
          <td>01.02.2026–28.02.2026 (договор)</td>
          <td>Долгосрочная (договор Д-045)</td>
          <td>А555АА750</td>
          <td>Сектор Б, ПМ 201</td>
          <td><span class="wf-badge">Подтверждена</span></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% include "partials/admin-booking-modal.njk" %}
{% include "partials/admin-booking-edit-modal.njk" %}
{% include "partials/admin-contract-edit-modal.njk" %}
{% include "partials/admin-client-modal.njk" %}
{% endblock %}
