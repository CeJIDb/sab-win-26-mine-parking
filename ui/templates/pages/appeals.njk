{% extends "layouts/lk.njk" %}

{% block title %}Обращения — ЛК клиента{% endblock %}
{% block header_subtitle %}Обращения в службу поддержки{% endblock %}

{% block content %}
  <p class="wf-context"><a href="dashboard.html">Главная ЛК</a> → Обращения</p>
  <h2>Обращения</h2>

  <section class="wf-section">
    <h3>Мои обращения</h3>
    <p class="wf-muted">Здесь отображаются ваши запросы в службу поддержки, связанные с бронированиями, договорами, сессиями и оплатами.</p>

    <div class="wf-actions">
      <a href="#appeal-create-modal" class="wf-btn">Создать обращение</a>
    </div>

    <ul class="wf-list wf-list--compact">
      <li>
        <strong>#AP-001</strong> — Проблема с въездом на парковку —
        Статус: <strong>Открыто</strong> —
        Обновлено: 24.02.2026
        <button type="button">Просмотреть</button>
      </li>
      <li>
        <strong>#AP-002</strong> — Вопрос по автосписанию по договору —
        Статус: <strong>В работе</strong> —
        Обновлено: 23.02.2026
        <button type="button">Просмотреть</button>
      </li>
      <li>
        <strong>#AP-003</strong> — Уточнение по истории парковочной сессии —
        Статус: <strong>Закрыто</strong> —
        Обновлено: 20.02.2026
        <button type="button">Просмотреть</button>
      </li>
    </ul>
  </section>

  <section id="appeal-create-modal" class="wf-modal" role="dialog" aria-modal="true" aria-labelledby="appeal-create-title">
    <div class="wf-modal__dialog wf-section">
      <header class="wf-modal__header">
        <h3 id="appeal-create-title">Создать обращение</h3>
        <a href="#main-content" class="wf-btn wf-modal__close" aria-label="Закрыть окно">✕</a>
      </header>
      <form class="wf-form">
        <div class="wf-field">
          <label for="appeal-subject">Тема обращения</label>
          <input id="appeal-subject" type="text" required placeholder="Кратко опишите суть обращения">
        </div>
        <div class="wf-field">
          <label for="appeal-category">Категория</label>
          <select id="appeal-category" required>
            <option value="">— выбрать —</option>
            <option value="booking">Бронирование</option>
            <option value="contract">Договор</option>
            <option value="session">Парковочная сессия</option>
            <option value="payment">Оплата</option>
            <option value="access">Доступ / пропуск</option>
            <option value="other">Другое</option>
          </select>
        </div>
        <div class="wf-field">
          <label for="appeal-related">Связанный объект (№ договора / ID сессии / № брони)</label>
          <input id="appeal-related" type="text" placeholder="Например: Договор №123 / Сессия #456">
        </div>
        <div class="wf-field">
          <label for="appeal-text">Описание</label>
          <textarea id="appeal-text" rows="5" required placeholder="Подробно опишите проблему или вопрос, укажите необходимые детали (даты, номера ТС, парковочные места и т.п.)."></textarea>
        </div>
        <div class="wf-field">
          <label for="appeal-attachment">Вложения (при необходимости)</label>
          <input id="appeal-attachment" type="file" disabled>
          <p class="wf-muted">В MVP можно описать ситуацию текстом; поле для файлов добавлено как заготовка.</p>
        </div>
        <p class="wf-muted">
          Ответ будет направлен на контактные данные из раздела «Профиль». При необходимости оператор может связаться с вами по телефону.
        </p>
        <div class="wf-actions">
          <button type="submit">Отправить обращение</button>
          <a href="#main-content" class="wf-btn-link">Отмена</a>
        </div>
      </form>
    </div>
  </section>
{% endblock %}

