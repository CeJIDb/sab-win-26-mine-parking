{% extends "layouts/admin.njk" %}

{% set current_nav = 'admin-contracts' %}

{% block title %}Договоры — ЛК админа{% endblock %}
{% block header_breadcrumbs %}<a href="debts.html">Клиенты</a><span class="wf-breadcrumbs__sep">/</span><span class="wf-breadcrumbs__current">Договоры</span>{% endblock %}

{% block auxiliary_nav %}
  {% set nav_current = current_nav %}
  {% include "partials/nav-clients.njk" %}
{% endblock %}

{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Управление договорами</h2>
  </div>

<section class="wf-section">
  <h3>Реестр договоров</h3>
  <div class="wf-actions">
    <a href="contracts-create.html" class="wf-btn">Создать договор</a>
  </div>
  <form class="wf-form sessions-filters" aria-label="Фильтр реестра договоров">
    <div class="filters-row">
      <div class="wf-field">
        <label for="search-contract-admin-number">№ договора</label>
        <input id="search-contract-admin-number" type="text" placeholder="Д-045">
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-client-type">Тип клиента</label>
        <select id="search-contract-admin-client-type">
          <option value="">Любой</option>
          <option value="fl">ФЛ</option>
          <option value="yl">ЮЛ</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-client">Клиент</label>
        <input id="search-contract-admin-client" type="text" placeholder="ФИО или название организации">
      </div>
      <div class="wf-field">
        <label for="search-contract-admin-status">Статус договора</label>
        <select id="search-contract-admin-status">
          <option value="">Любой</option>
          <option value="active">Активен</option>
          <option value="ending-soon">Скоро истекает</option>
          <option value="finished">Завершён</option>
          <option value="overdue">Просрочка</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Применить</button>
        <button type="button">Сброс</button>
      </div>
    </div>
  </form>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">№ договора</th>
          <th scope="col">Тип клиента</th>
          <th scope="col">Клиент</th>
          <th scope="col">Период</th>
          <th scope="col">Статус договора</th>
          <th scope="col">Задолженность</th>
          <th scope="col">ТС / ПМ</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href="#admin-modal-contract-view">Д-045</a></td>
          <td>ФЛ</td>
          <td><a href="#admin-modal-client-fl">Иванов Иван Иванович</a></td>
          <td>01.01.2026–31.12.2026</td>
          <td><span class="wf-badge">Активен</span></td>
          <td>Нет</td>
          <td>2 ТС, 2 ПМ</td>
        </tr>
        <tr>
          <td><a href="#admin-modal-contract-view">Д-052</a></td>
          <td>ЮЛ</td>
          <td><a href="#admin-modal-client-yl">ООО «Ромашка»</a></td>
          <td>15.02.2026–14.05.2026</td>
          <td><span class="wf-badge">Скоро истекает</span></td>
          <td>Просрочка 2 дня</td>
          <td>5 ТС, 4 ПМ</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% include "partials/admin-contract-modal.njk" %}
{% include "partials/admin-client-modal.njk" %}

<section class="wf-section">
  <h3>Шаблоны договоров</h3>
  <p class="wf-muted">Типовые шаблоны договоров, которые используются при оформлении для разных типов клиентов.</p>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">Тип клиента</th>
          <th scope="col">Название шаблона</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Физическое лицо</td>
          <td>Долгосрочная парковка (ФЛ)</td>
        </tr>
        <tr>
          <td>Юридическое лицо</td>
          <td>Долгосрочная парковка (ЮЛ)</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
