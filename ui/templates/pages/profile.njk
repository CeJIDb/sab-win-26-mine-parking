{% extends "layouts/lk.njk" %}

{% set current_nav = 'profile' %}

{% block title %}Настройки профиля — ЛК клиента{% endblock %}

{% block content %}
  <h2>Настройки профиля</h2>
  <form class="wf-form">
    <div class="wf-field wf-field--inline-control">
      <label for="prof-phone">Текущий телефон</label>
      <div class="wf-inline">
        <input id="prof-phone" type="tel" placeholder="+7 …" readonly>
        <a href="#phone-change-modal" class="wf-btn-link">Изменить номер</a>
      </div>
    </div>
    <div class="wf-field wf-field--inline-control">
      <label for="prof-email">E-mail</label>
      <div class="wf-inline">
        <input id="prof-email" type="email" placeholder="email@example.com" readonly>
        <a href="#email-change-modal" class="wf-btn-link">Изменить e-mail</a>
      </div>
    </div>
    <div class="wf-field">
      <a href="#password-change-modal" class="wf-btn">Изменить пароль</a>
    </div>
    <div class="wf-field">
      <label for="prof-last-name">Фамилия</label>
      <input id="prof-last-name" type="text" placeholder="Иванов">
    </div>
    <div class="wf-field">
      <label for="prof-first-name">Имя</label>
      <input id="prof-first-name" type="text" placeholder="Иван">
    </div>
    <div class="wf-field">
      <label for="prof-middle-name">Отчество (необязательно)</label>
      <input id="prof-middle-name" type="text" placeholder="Иванович">
    </div>
    <div class="wf-field">
      <a href="#passport-modal" class="wf-btn">Паспортные данные</a>
    </div>
    <h3>Настройки уведомлений</h3>
    <div class="wf-field wf-field--checkbox">
      <label for="notify-sessions">
        <input id="notify-sessions" type="checkbox" checked>
        <span>О парковочных сессиях: въезд/выезд, превышение времени, блокировки доступа</span>
      </label>
    </div>
    <div class="wf-field wf-field--checkbox">
      <label for="notify-bookings">
        <input id="notify-bookings" type="checkbox" checked>
        <span>О бронированиях: создание, изменение, отмена, напоминания перед началом</span>
      </label>
    </div>
    <div class="wf-field wf-field--checkbox">
      <label for="notify-contracts">
        <input id="notify-contracts" type="checkbox" checked>
        <span>О договорах: активация, продление, истечение срока, наличие задолженности</span>
      </label>
    </div>
    <div class="wf-field wf-field--checkbox">
      <label for="notify-payments">
        <input id="notify-payments" type="checkbox" checked>
        <span>Об оплатах и счетах: новые счета к оплате, успешные и отклонённые платежи</span>
      </label>
    </div>
    <div class="wf-field wf-field--checkbox">
      <label for="notify-marketing">
        <input id="notify-marketing" type="checkbox">
        <span>Маркетинговые рассылки: акции, новости парковки и партнёров</span>
      </label>
    </div>
    <div class="wf-actions">
      <button type="submit">Сохранить</button>
      <a href="../site/login.html" class="wf-btn">Выход</a>
    </div>
  </form>

  {% include "partials/profile-phone-modal.njk" %}
  {% include "partials/profile-email-modal.njk" %}
  {% include "partials/profile-password-modal.njk" %}
  {% include "partials/profile-passport-modal.njk" %}
{% endblock %}
