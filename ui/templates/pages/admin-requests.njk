{% extends "layouts/admin.njk" %}
{% set current_nav = 'admin-requests' %}
{% block title %}Обращения — ЛК админа{% endblock %}
{% block header_breadcrumbs %}<span class="wf-breadcrumbs__current">Обращения</span>{% endblock %}
{% block content %}
  <div class="wf-page-head">
    <button type="button" class="wf-back">Назад</button>
    <h2>Обращения и инциденты</h2>
  </div>
<!-- WF-11: Обращения управляющего (П. 3 — работа с обращениями, поиск по обращениям и инцидентам) -->

<section class="wf-section">
  <h3>Реестр обращений и инцидентов</h3>
  <form class="wf-form sessions-filters" aria-label="Фильтры по обращениям и инцидентам">
    <div class="filters-row">
      <div class="wf-field">
        <label for="search-requests-text">Номер / клиент / тема</label>
        <input id="search-requests-text" type="text" placeholder="№ обращения, ФИО, тема">
      </div>
      <div class="wf-field">
        <label for="search-requests-client-type">Тип клиента</label>
        <select id="search-requests-client-type">
          <option value="">Любой</option>
          <option value="fl">ФЛ</option>
          <option value="yl">ЮЛ</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="search-requests-type">Тип обращения</label>
        <select id="search-requests-type">
          <option value="">Все</option>
          <option value="appeal">Обращение</option>
          <option value="incident">Инцидент</option>
        </select>
      </div>
      <div class="wf-field">
        <label for="search-requests-status">Статус</label>
        <select id="search-requests-status">
          <option value="">Любой</option>
          <option value="new">Новый</option>
          <option value="in-progress">В работе</option>
          <option value="closed">Закрыто</option>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit">Применить</button>
        <button type="button">Сброс</button>
      </div>
    </div>
  </form>
  <div class="wf-table-wrap">
    <table class="wf-table">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Тип клиента</th>
          <th scope="col">Клиент</th>
          <th scope="col">Тип обращения</th>
          <th scope="col">Тема</th>
          <th scope="col">Дата и время</th>
          <th scope="col">Статус</th>
          <th scope="col">Источник</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href="#admin-modal-request-view">#A‑1025</a></td>
          <td>ФЛ</td>
          <td><a href="#admin-modal-client-fl">Иванов Иван Иванович</a></td>
          <td>Обращение</td>
          <td>Вопрос по начислению оплаты</td>
          <td>24.02.2026 10:30</td>
          <td><span class="wf-badge wf-badge--new">Новый</span></td>
          <td>Клиент (ЛК)</td>
        </tr>
        <tr>
          <td><a href="#admin-modal-request-view">#I‑034</a></td>
          <td>ЮЛ</td>
          <td><a href="#admin-modal-client-yl">ООО «Ромашка»</a></td>
          <td>Инцидент</td>
          <td>Отказ во въезде при активном договоре</td>
          <td>24.02.2026 09:30</td>
          <td><span class="wf-badge wf-badge--in-progress">В работе</span></td>
          <td>КПП / журнал событий</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% include "partials/admin-request-modal.njk" %}
{% include "partials/admin-client-modal.njk" %}
{% endblock %}
