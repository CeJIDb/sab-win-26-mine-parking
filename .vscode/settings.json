{
  "markdown.mermaid.enabled": true,
  "cSpell.language": "en,ru",
  "cSpell.enabledLanguageIds": ["markdown", "plaintext", "git-commit"],
  "ltex.enabled": true,
  "ltex.language": "auto",
  "ltex.diagnosticSeverity": "information",
  "ltex.enabledScopes": ["markdown"],
  "ltex.additionalRules.motherTongue": "ru-RU",
  "[markdown]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    },
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "markdownlint.run": "onSave",
  "sqltools.connections": [
    {
      "ssh": "Disabled",
      "previewLimit": 50,
      "server": "localhost",
      "port": 5432,
      "askForPassword": true,
      "driver": "PostgreSQL",
      "name": "WSL Postgres",
      "database": "practice",
      "username": "practice"
    }
  ]
}
