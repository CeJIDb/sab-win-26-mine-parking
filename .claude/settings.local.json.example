{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Пример персональных настроек Claude Code. Скопируй в .claude/settings.local.json (файл в .gitignore) и правь под себя. В .claude/settings.json лежат общекомандные deny-правила — дополняй, а не переопределяй.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"[System.Media.SystemSounds]::Asterisk.Play(); Start-Sleep -Milliseconds 800\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"[System.Media.SystemSounds]::Exclamation.Play(); Start-Sleep -Milliseconds 800\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ]
  }
}
